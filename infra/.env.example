# =============================================================================
# Flowa Self-Host Environment Template
# Copy to /opt/supabase/docker/.env và điền secrets thật trước khi `docker compose up`
# =============================================================================

############
# DOMAINS  #
############
API_EXTERNAL_URL=https://api.flowa.one
SUPABASE_PUBLIC_URL=https://api.flowa.one
STUDIO_PUBLIC_URL=https://studio.flowa.one
SITE_URL=https://app.flowa.one
ADDITIONAL_REDIRECT_URLS=https://app.flowa.one,https://flowa.one,http://localhost:8080

############
# POSTGRES #
############
POSTGRES_HOST=db
POSTGRES_DB=postgres
POSTGRES_PORT=5432
POSTGRES_PASSWORD=__GENERATE_STRONG_PASSWORD_64_CHARS__
JWT_SECRET=__GENERATE_RANDOM_40_CHARS__
JWT_EXPIRY=3600

# Khóa anon/service role mới (tự generate bằng `supabase status` sau khi boot)
ANON_KEY=__REGENERATE_AFTER_FIRST_BOOT__
SERVICE_ROLE_KEY=__REGENERATE_AFTER_FIRST_BOOT__

############
# AI (SELF-HOST) — bắt buộc khi không còn Lovable Gateway
############
SELF_HOSTED_MODE=true
OPENROUTER_API_KEY=__YOUR_OPENROUTER_KEY__
NINE_ROUTER_BASE_URL=__YOUR_9ROUTER_URL__
NINE_ROUTER_API_KEY=__YOUR_9ROUTER_KEY__
DASHSCOPE_API_KEY=__YOUR_DASHSCOPE_KEY__
GEMINI_API_KEY=__OPTIONAL_DIRECT_GEMINI__
OPENAI_API_KEY=__OPTIONAL_DIRECT_OPENAI__

# Image gen providers
POYO_API_KEY=__YOUR_POYO_KEY__
KIE_AI_API_KEY=__YOUR_KIE_KEY__

############
# CRYPTO (encrypt social tokens, OAuth state)
############
# Same key as Lovable Cloud để decrypt được data migrate sang
ENCRYPTION_KEY=__COPY_FROM_LOVABLE_CLOUD_SECRETS__

############
# AUTH — Email
############
ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=false
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=__RESEND_API_KEY__
SMTP_SENDER_NAME=Flowa
SMTP_ADMIN_EMAIL=admin@flowa.one

############
# AUTH — OAuth providers (21+ — đăng ký lại redirect URI ở từng Console)
# Pattern redirect URI mới: https://api.flowa.one/auth/v1/callback
############
GOTRUE_EXTERNAL_GOOGLE_ENABLED=true
GOTRUE_EXTERNAL_GOOGLE_CLIENT_ID=
GOTRUE_EXTERNAL_GOOGLE_SECRET=
GOTRUE_EXTERNAL_GOOGLE_REDIRECT_URI=https://api.flowa.one/auth/v1/callback

GOTRUE_EXTERNAL_FACEBOOK_ENABLED=true
GOTRUE_EXTERNAL_FACEBOOK_CLIENT_ID=
GOTRUE_EXTERNAL_FACEBOOK_SECRET=

# Các provider khác (TikTok, LinkedIn, X, Threads, Instagram, Zalo, GBP, Blogger, Bluesky, …)
# dùng custom edge function callback, KHÔNG qua GoTrue → chỉ cần secret trong edge env

TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
THREADS_APP_ID=
THREADS_APP_SECRET=
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
ZALO_APP_ID=
ZALO_APP_SECRET=
GBP_CLIENT_ID=
GBP_CLIENT_SECRET=
BLOGGER_CLIENT_ID=
BLOGGER_CLIENT_SECRET=
BLUESKY_CLIENT_ID=https://app.flowa.one/bluesky-client-metadata.json
BLUESKY_PRIVATE_KEY_JWK=__JWK_JSON__

############
# STORAGE
############
STORAGE_BACKEND=file
FILE_SIZE_LIMIT=52428800
STORAGE_S3_BUCKET=
GLOBAL_S3_BUCKET=

############
# REALTIME
############
REALTIME_DB_ENC_KEY=__GENERATE_32_CHARS__

############
# TIMEZONE — cron jobs chạy theo giờ VN
############
TZ=Asia/Ho_Chi_Minh

############
# PAYMENT GATEWAYS
############
VNPAY_TMN_CODE=
VNPAY_SECRET_KEY=
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=
STRIPE_SECRET_KEY=

############
# THIRD-PARTY (Telegram, SEMrush, etc.)
############
TELEGRAM_BOT_TOKEN=
SEMRUSH_API_KEY=
