{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "mcp__github__merge_pull_request",
      "mcp__github__update_pull_request_branch",
      "mcp__github__enable_pr_auto_merge"
    ],
    "ask": [
      "mcp__github__disable_pr_auto_merge",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git branch -D*)",
      "Bash(git reset --hard*)"
    ]
  }
}
